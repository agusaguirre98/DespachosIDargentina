# Flask configuration
FLASK_ENV=development
FLASK_DEBUG=1

# Primary SQL Server database used by SQLAlchemy.
# Example: mssql+pyodbc://user:pass@host:1433/DBNAME?driver=ODBC+Driver+18+for+SQL+Server
SQLALCHEMY_DATABASE_URI=

# Read-only connection string to the ASIGNADOR database.
ASIGNADOR_DB_URI=

# Azure AD application used to authenticate against Microsoft Graph / SharePoint.
AZ_TENANT_ID=
AZ_CLIENT_ID=
AZ_CLIENT_SECRET=

# SharePoint site that stores the PDF sources.
SP_SITE_URL=

# Optional overrides
#MAX_CONTENT_LENGTH=31457280
